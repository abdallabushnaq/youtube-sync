<configuration>

    <!--
      All log output goes to a rolling file in the current working directory.
      This keeps the terminal clean so progress bars are not interleaved with log lines.
      Logs are rolled daily; the last 7 days are kept.
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>youtube-sync.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>youtube-sync.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} — %msg%n</pattern>
        </encoder>
    </appender>

    <!--
      WARN and ERROR always appear in the terminal so the user can see what went wrong
      without having to open the log file.  INFO/DEBUG stay file-only to avoid cluttering
      the progress-bar output.
    -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <encoder>
            <pattern>%-5level %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Suppress noisy Google HTTP client debug output unless explicitly needed -->
    <logger name="com.google" level="WARN"/>
    <logger name="org.eclipse.jetty" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="FILE"/>
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>

